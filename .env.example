# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=          # Bot token from @BotFather

# ── LLM (any OpenAI-compatible endpoint) ─────────────────────────
# OpenAI:   https://api.openai.com/v1
# Groq:     https://api.groq.com/openai/v1
# Together: https://api.together.xyz/v1
# Ollama:   http://localhost:11434/v1  (LLM_API_KEY=ollama)
# Mistral:  https://api.mistral.ai/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=             # API key for your LLM provider
LLM_MODEL=gpt-4o-mini

# ── Card Backend ─────────────────────────────────────────────────
CARD_BACKEND=anki        # "anki" or "mochi"

# Anki (requires AnkiConnect plugin + Anki running locally)
# In Docker: use host.docker.internal instead of localhost
ANKI_CONNECT_URL=http://localhost:8765
ANKI_DECK=Language::Daily

# Mochi
MOCHI_API_KEY=
MOCHI_DECK_ID=
MOCHI_BASE_URL=https://app.mochi.cards/api   # override for self-hosted

# ── Database (Postgres) ───────────────────────────────────────────
DB_HOST=db               # service name in docker-compose, or localhost for local dev
DB_PORT=5432
DB_NAME=merkly
DB_USER=postgres
DB_PASSWORD=postgres
