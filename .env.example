TELEGRAM_TOKEN=your_bot_token_here

# LLM — any OpenAI-compatible endpoint
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1
# Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1
# Together: LLM_BASE_URL=https://api.together.xyz/v1
# Ollama:   LLM_BASE_URL=http://localhost:11434/v1  + LLM_API_KEY=ollama
# Mistral:  LLM_BASE_URL=https://api.mistral.ai/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini

# Card backend: "anki" or "mochi"
CARD_BACKEND=anki

# Anki (if CARD_BACKEND=anki) — AnkiConnect plugin must be running
ANKI_CONNECT_URL=http://host.docker.internal:8765

# Mochi (if CARD_BACKEND=mochi)
MOCHI_API_KEY=your_mochi_api_key
MOCHI_DECK_ID=your_deck_id

# Storage
DATA_DIR=/app/data
