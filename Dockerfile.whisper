FROM python:3.12-slim

RUN apt-get update && apt-get install -y ffmpeg && rm -rf /var/lib/apt/lists/*

RUN pip install faster-whisper faster-whisper-server

EXPOSE 8000

ENV WHISPER__MODEL=base
ENV WHISPER__INFERENCE_DEVICE=cpu

CMD ["uvicorn", "faster_whisper_server.main:app", "--host", "0.0.0.0", "--port", "8000"]
